{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "spike-digital",
  "main": ".open-next/worker.js",
  "compatibility_date": "2026-06-01",
  "compatibility_flags": ["nodejs_compat"],
  "assets": {
    "directory": ".open-next/assets",
    "binding": "ASSETS"
  },
  "vars": {
    // Kill switch: "false" replaces the chat with the contact form (FR-1.8/FR-1.10).
    "CHAT_ENABLED": "true",
    "AGENT_MODEL": "gemini-2.5-flash",
    "MAX_SESSION_TOKENS": "50000",
    "MAX_SESSION_MESSAGES": "30",
    "LEAD_NOTIFY_EMAIL": "zolika84@gmail.com",
    "CAL_LINK": "spike-land/discovery"
  },
  "durable_objects": {
    "bindings": [
      {
        "name": "CHAT_SESSION",
        "class_name": "ChatSessionDO",
        "script_name": "spike-chat-state"
      }
    ]
  },
  // Per-IP rate limits (FR-1.8/FR-6). namespace_id values are arbitrary,
  // locally-unique identifiers chosen by us, not remote resource ids.
  "ratelimits": [
    { "name": "CHAT_RATE_LIMITER", "namespace_id": "1001", "simple": { "limit": 20, "period": 60 } },
    { "name": "CONTACT_RATE_LIMITER", "namespace_id": "1002", "simple": { "limit": 5, "period": 60 } }
  ],
  "analytics_engine_datasets": [{ "binding": "FUNNEL_EVENTS", "dataset": "spike_digital_funnel" }]
  // Secrets (set via `wrangler secret put`): GEMINI_API_KEY, RESEND_API_KEY,
  // SESSION_SIGNING_SECRET, PII_ENCRYPTION_KEY. Optional var: LEAD_WEBHOOK_URL.
}
