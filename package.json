{
  "name": "spike-digital",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "preview": "npm run kb && opennextjs-cloudflare build && wrangler dev -c wrangler.jsonc -c workers/chat-state/wrangler.jsonc",
    "deploy": "npm run kb && opennextjs-cloudflare build && wrangler deploy -c workers/chat-state/wrangler.jsonc && opennextjs-cloudflare deploy",
    "lint": "biome check .",
    "format": "biome format --write .",
    "typecheck": "tsc --noEmit && tsc --noEmit -p workers/chat-state/tsconfig.json",
    "test": "vitest run",
    "cf-typegen": "wrangler types --env-interface CloudflareEnv cloudflare-env.d.ts",
    "kb": "node scripts/build-kb.ts",
    "prebuild": "node scripts/build-kb.ts",
    "pretypecheck": "node scripts/build-kb.ts",
    "eval": "node evals/run-evals.ts",
    "test:e2e": "playwright test"
  },
  "dependencies": {
    "@google/genai": "^2.11.0",
    "next": "16.2.10",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "resend": "^6.17.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.2",
    "@cloudflare/workers-types": "^4.20260702.1",
    "@lhci/cli": "^0.15.1",
    "@opennextjs/cloudflare": "^1.20.1",
    "@playwright/test": "^1.61.1",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^4.1.9",
    "wrangler": "^4.107.0",
    "yaml": "^2.9.0"
  },
  "type": "module"
}
